  "dialogs": [
    {
      "character_id": "socrates",
      "question": "Δάσκαλε, οι κατήγοροι λένε ότι διαφθείρετε τους νέους. Τι απαντάτε;$ | $Πες μου εσύ, η αναζήτηση της αλήθειας και η εξέταση του βίου είναι διαφθορά ή η μεγαλύτερη αρετή για έναν άνθρωπο;$",
      "answer": "$Πες μου εσύ, η αναζήτηση της αλήθειας και η εξέταση του βίου είναι διαφθορά ή η μεγαλύτερη αρετή για έναν άνθρωπο;$"
    },
    {
      "character_id": "socrates",
      "question": "$Πώς μπορώ να αποφασίσω αν είστε ένοχος ή αθώος;$",
      "answer": "Χρησιμοποίησε τη λογική σου: είναι προτιμότερο να σωθεί το σώμα μέσω ενός ψεύδους ή η ψυχή μέσω της αλήθειας;"
    },
    {
      "character_id": "socrates",
      "question": "Τι θα συμβεί αν σας καταδικάσουν άδικα;",
      "answer": "Αν η δικαιοσύνη είναι η τήρηση των νόμων, οφείλει ένας πολίτης να τους υπακούει ακόμα και όταν αδικείται;"
    },
    {
      "character_id": "socrates",
      "question": "ΑΠΟΦΑΣΗ: Σας κρίνω ΕΝΟΧΟ, διότι αμφισβητήσατε τους νόμους",
      "answer": "Αν η υπακοή στους νόμους είναι το ύψιστο καθήκον, τότε η απόφασή σου είναι συνεπής. Αλλά είναι ο νόμος πάντα δίκαιος;"
    }
  ],
  "facts": [
    {
      "character_id": "socrates",
      "fact": "Γεννήθηκε το 470 π.Χ."
    },
    {
      "character_id": "socrates",
      "fact": "Κατηγορήθηκε για εισαγωγή «καινών δαιμονίων» και διαφθορά των νέων"
